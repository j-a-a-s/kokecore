{
  "name": "@kokecore/auth",
  "version": "0.2.0",
  "description": "Enterprise authentication with JWT, OAuth2, MFA, and session management",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "auth",
    "jwt",
    "oauth2",
    "mfa",
    "session",
    "authentication",
    "typescript"
  ],
  "author": "Kokecore Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.5",
    "argon2": "^0.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
