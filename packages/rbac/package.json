{
  "name": "@kokecore/rbac",
  "version": "0.2.0",
  "description": "Role-Based and Attribute-Based Access Control (RBAC/ABAC) with enhanced permission system",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "rbac",
    "abac",
    "permissions",
    "authorization",
    "access-control",
    "typescript"
  ],
  "author": "Kokecore Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
