{
  "name": "@kokecore/validation",
  "version": "0.2.0",
  "description": "Comprehensive validation and sanitization library with international support",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "validation",
    "sanitization",
    "chilean-rut",
    "money",
    "phone",
    "typescript",
    "zod"
  ],
  "author": "Kokecore Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "iban": "^0.0.14",
    "libphonenumber-js": "^1.10.44",
    "zod": "^3.22.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
