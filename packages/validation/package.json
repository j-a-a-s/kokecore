{
  "name": "@kokecore/validation",
  "version": "0.2.0",
  "private": true,
  "sideEffects": false,
  "description": "Comprehensive validation and sanitization library with international support",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "default": "./dist/public.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "validation",
    "sanitization",
    "chilean-rut",
    "money",
    "phone",
    "typescript",
    "zod"
  ],
  "author": "KOKE GROUP",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "iban": "^0.0.14",
    "libphonenumber-js": "^1.10.44",
    "zod": "^4.4.3"
  }
}
