{
  "name": "@kokecore/calendar",
  "version": "0.3.0-beta.0",
  "private": true,
  "sideEffects": false,
  "description": "Enterprise calendar synchronization with Google Calendar, Microsoft Graph, and Apple Calendar",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "default": "./dist/public.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "calendar",
    "google-calendar",
    "outlook",
    "microsoft-graph",
    "apple-calendar",
    "sync",
    "typescript"
  ],
  "author": "KOKE GROUP",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@azure/msal-node": "^5.4.1",
    "@microsoft/microsoft-graph-client": "^3.0.5",
    "date-fns": "^2.30.0",
    "googleapis": "^173.0.0",
    "isomorphic-fetch": "^3.0.0",
    "rrule": "^2.7.2",
    "zod": "^4.4.3"
  }
}
